%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8761bd1239105c04ba7459d32fa8b614, type: 3}
  m_Name: LocalizationDatabase_Main
  m_EditorClassIdentifier: Assembly-CSharp::LocalizationDatabase
  entries:
  - key: PLAY
    english: PLAY
    deutsch: SPIELEN
    francais: JOUER
    italiano: GIOCA
  - key: INSTRUCTIONS
    english: INSTRUCTIONS
    deutsch: ANLEITUNG
    francais: INSTRUCTIONS
    italiano: ISTRUZIONI
  - key: SETTINGS
    english: SETTINGS
    deutsch: EINSTELLUNGEN
    francais: "PARAM\xC8TRES"
    italiano: IMPOSTAZIONI
  - key: QUIT
    english: QUIT
    deutsch: BEENDEN
    francais: QUITTER
    italiano: ESCI
  - key: NEXT
    english: NEXT
    deutsch: WEITER
    francais: SUIVANT
    italiano: AVANTI
  - key: READY
    english: READY
    deutsch: BEREIT
    francais: "PR\xCAT"
    italiano: PRONTO
  - key: START
    english: START
    deutsch: START
    francais: COMMENCER
    italiano: INIZIA
  - key: CONTINUE
    english: CONTINUE
    deutsch: WEITER
    francais: CONTINUER
    italiano: CONTINUA
  - key: CLOSE
    english: CLOSE
    deutsch: SCHLIESSEN
    francais: FERMER
    italiano: CHIUDI
  - key: DIALOGUE_INTRO_001
    english: 'Darwin: Welcome to my laboratory!'
    deutsch: 'Darwin: Willkommen in meinem Labor!'
    francais: 'Darwin: Bienvenue dans mon laboratoire !'
    italiano: 'Darwin: Benvenuto nel mio laboratorio!'
  - key: DIALOGUE_INTRO_002
    english: 'Player: What are all these bones?'
    deutsch: 'Spieler: Was sind all diese Knochen?'
    francais: 'Joueur : Que sont tous ces os ?'
    italiano: 'Giocatore: Cosa sono tutte queste ossa?'
  - key: DIALOGUE_INTRO_003
    english: 'Darwin: Each one tells a story.'
    deutsch: "Darwin: Jeder einzelne erz\xE4hlt eine Geschichte."
    francais: 'Darwin : Chacun raconte une histoire.'
    italiano: 'Darwin: Ognuna racconta una storia.'
  - key: DIALOGUE_INTRO_004
    english: 'Musowl: Hoo! I love bone stories!'
    deutsch: 'Musowl: Huhuu! Ich liebe Knochen-Geschichten!'
    francais: "Musowl : Hou ! J\u2019adore les histoires d\u2019os !"
    italiano: 'Musowl: Hoo! Adoro le storie di ossa!'
  - key: DIALOGUE_INTRO_005
    english: 'Darwin: This is the Chrono-Engine. It lets us travel through time.'
    deutsch: "Darwin: Das ist die Chrono-Maschine. Sie erm\xF6glicht uns, durch die
      Zeit zu reisen."
    francais: 'Darwin : Voici le Chrono-Moteur. Il nous permet de voyager dans le
      temps.'
    italiano: "Darwin: Questo \xE8 il Crono-Motore. Ci permette di viaggiare nel
      tempo."
  - key: DIALOGUE_INTRO_006
    english: 'Player: To the past or future?'
    deutsch: 'Spieler: In die Vergangenheit oder in die Zukunft?'
    francais: "Joueur : Vers le pass\xE9 ou le futur ?"
    italiano: 'Giocatore: Nel passato o nel futuro?'
  - key: DIALOGUE_INTRO_007
    english: 'Darwin: To the past only. It is how I have made most of my discoveries.'
    deutsch: 'Darwin: Nur in die Vergangenheit. So habe ich die meisten meiner Entdeckungen
      gemacht.'
    francais: "Darwin : Seulement vers le pass\xE9. C\u2019est ainsi que j\u2019ai
      fait la plupart de mes d\xE9couvertes."
    italiano: "Darwin: Solo nel passato. \xC8 cos\xEC che ho fatto la maggior parte
      delle mie scoperte."
  - key: DIALOGUE_INTRO_008
    english: 'Musowl: Hoo! Let''s begin when you are ready!'
    deutsch: Huhuu! Lass uns beginnen, wenn du bereit bist!
    francais: "Hou ! Commen\xE7ons quand tu es pr\xEAt !"
    italiano: Hoo! Iniziamo quando sei pronto!
  - key: STAGE1_INTRO_001
    english: Drag the skull clue into the matching slot.
    deutsch: "Ziehe den Sch\xE4del-Hinweis in den passenden Platz."
    francais: "Fais glisser l\u2019indice du cr\xE2ne dans l\u2019emplacement correspondant."
    italiano: "Trascina l\u2019indizio del teschio nello spazio corrispondente."
  - key: STAGE1_INTRO_002
    english: Excellent! Now we can begin the mission.
    deutsch: "Ausgezeichnet! Jetzt k\xF6nnen wir mit der Mission beginnen."
    francais: Excellent ! Nous pouvons maintenant commencer la mission.
    italiano: Eccellente! Ora possiamo iniziare la missione.
  - key: STAGE1_ASSEMBLY_001
    english: Assemble the Brasilodon skeleton.
    deutsch: Setze das Brasilodon-Skelett zusammen.
    francais: Assemble le squelette du Brasilodon.
    italiano: Assembla lo scheletro del Brasilodon.
  - key: STAGE1_ASSEMBLY_002
    english: 'Correct pieces placed: {current}/{total}'
    deutsch: 'Richtige Teile platziert: {current}/{total}'
    francais: "Pi\xE8ces correctes plac\xE9es : {current}/{total}"
    italiano: 'Pezzi corretti posizionati: {current}/{total}'
  - key: STAGE1_ASSEMBLY_003
    english: Skeleton assembled! Click each bone to learn its name and function,
      then continue.
    deutsch: Skelett zusammengesetzt! Klicke auf jeden Knochen, um seinen Namen und
      seine Funktion zu lernen, und fahre dann fort.
    francais: "Squelette assembl\xE9 ! Clique sur chaque os pour apprendre son nom
      et sa fonction, puis continue."
    italiano: Scheletro assemblato! Clicca su ogni osso per imparare il suo nome
      e la sua funzione, poi continua.
  - key: BONEINFO_DEFAULT_NAME
    english: Select a bone
    deutsch: "W\xE4hle einen Knochen"
    francais: "S\xE9lectionne un os"
    italiano: Seleziona un osso
  - key: BONEINFO_DEFAULT_DESC
    english: Click a bone card to learn more about it.
    deutsch: "Klicke auf eine Knochenkarte, um mehr dar\xFCber zu erfahren."
    francais: "Clique sur une carte d\u2019os pour en apprendre davantage."
    italiano: "Clicca su una carta osso per saperne di pi\xF9."
  - key: STAGE1_MISSION_TITLE
    english: LATE TRIASSIC ERA
    deutsch: "SP\xC4TE TRIAS"
    francais: "TRIAS SUP\xC9RIEUR"
    italiano: TARDO TRIASSICO
  - key: STAGE1_MISSION_DESC
    english: Find the clues that reveal the earliest mammal evidence.
    deutsch: "Finde die Hinweise, die den fr\xFChesten S\xE4ugetiernachweis zeigen."
    francais: "Trouve les indices qui r\xE9v\xE8lent les plus anciennes traces de
      mammif\xE8res."
    italiano: Trova gli indizi che rivelano le prime prove dei mammiferi.
  - key: STAGE1_COMPLETION_TITLE
    english: LEVEL 1 COMPLETED
    deutsch: LEVEL 1 ABGESCHLOSSEN
    francais: "NIVEAU 1 TERMIN\xC9"
    italiano: LIVELLO 1 COMPLETATO
  - key: STAGE1_COMPLETION_DESC
    english: "Woohoo! You assembled me! I am Brasilodon Quadrangularis \u2014 the
      earliest mammal ever!"
    deutsch: "Juhu! Du hast mich zusammengesetzt! Ich bin Brasilodon Quadrangularis
      \u2014 das fr\xFCheste S\xE4ugetier \xFCberhaupt!"
    francais: "Youhou ! Tu m\u2019as reconstitu\xE9 ! Je suis Brasilodon Quadrangularis
      \u2014 le tout premier mammif\xE8re !"
    italiano: "Woohoo! Mi hai assemblato! Sono il Brasilodon Quadrangularis \u2014
      il primo mammifero mai esistito!"
  - key: BONE_CRANIUM_NAME
    english: Cranium
    deutsch: Cranium
    francais: "Cr\xE2ne"
    italiano: Cranio
  - key: BONE_CRANIUM_DESC
    english: The skull is the hard bone that protects the brain. It helps keep the
      head safe and holds the eyes, nose, and mouth in place.
    deutsch: "Der Sch\xE4del ist der harte Knochen, der das Gehirn sch\xFCtzt. Er
      hilft, den Kopf sicher zu halten und tr\xE4gt die Augen, die Nase und den Mund."
    francais: "Le cr\xE2ne est l\u2019os dur qui prot\xE8ge le cerveau. Il aide \xE0
      garder la t\xEAte en s\xE9curit\xE9 et maintient les yeux, le nez et la bouche
      en place."
    italiano: "Il cranio \xE8 l\u2019osso duro che protegge il cervello. Aiuta a
      tenere al sicuro la testa e sostiene gli occhi, il naso e la bocca."
  - key: BONE_PELVIS_NAME
    english: Pelvis
    deutsch: Becken
    francais: Bassin
    italiano: Bacino
  - key: BONE_PELVIS_DESC
    english: The pelvis is a bone structure that connects the body to the legs and
      helps support balance, posture, and movement.
    deutsch: "Das Becken ist eine Knochenstruktur, die den K\xF6rper mit den Beinen
      verbindet und Gleichgewicht, Haltung und Bewegung unterst\xFCtzt."
    francais: "Le bassin est une structure osseuse qui relie le corps aux jambes
      et aide \xE0 soutenir l\u2019\xE9quilibre, la posture et le mouvement."
    italiano: "Il bacino \xE8 una struttura ossea che collega il corpo alle gambe
      e aiuta a sostenere equilibrio, postura e movimento."
  - key: BONE_FEMUR_NAME
    english: Femur
    deutsch: Femur
    francais: "F\xE9mur"
    italiano: Femore
  - key: BONE_FEMUR_DESC
    english: The femur is the large bone in the upper leg. It helps the body stand,
      walk, and move.
    deutsch: "Der Femur ist der gro\xDFe Knochen im oberen Bein. Er hilft dem K\xF6rper
      beim Stehen, Gehen und Bewegen."
    francais: "Le f\xE9mur est le grand os de la partie sup\xE9rieure de la jambe.
      Il aide le corps \xE0 se tenir debout, \xE0 marcher et \xE0 bouger."
    italiano: "Il femore \xE8 il grande osso della parte superiore della gamba. Aiuta
      il corpo a stare in piedi, camminare e muoversi."
  - key: BONE_HUMERUS_NAME
    english: Humerus
    deutsch: Humerus
    francais: "Hum\xE9rus"
    italiano: Omero
  - key: BONE_HUMERUS_DESC
    english: The humerus is a long bone in the front leg. It helps animals move,
      push, and support their body while walking. Humans have this bone in their
      arms.
    deutsch: "Der Humerus ist ein langer Knochen im vorderen Bein. Er hilft Tieren,
      sich zu bewegen, zu dr\xFCcken und ihren K\xF6rper beim Gehen zu st\xFCtzen.
      Beim Menschen befindet sich dieser Knochen im Arm."
    francais: "L\u2019hum\xE9rus est un os long de la patte avant. Il aide les animaux
      \xE0 bouger, pousser et soutenir leur corps en marchant. Chez l\u2019humain,
      cet os se trouve dans le bras."
    italiano: "L\u2019omero \xE8 un osso lungo della zampa anteriore. Aiuta gli animali
      a muoversi, spingere e sostenere il corpo mentre camminano. Negli esseri umani
      questo osso si trova nel braccio."
  - key: BONE_ASTRAGALOS_NAME
    english: Astragalos
    deutsch: Astragalos
    francais: Astragale
    italiano: Astragalo
  - key: BONE_ASTRAGALOS_DESC
    english: The astragalos is an important ankle bone. It helps connect the leg
      to the foot and allows smooth movement while walking.
    deutsch: "Der Astragalos ist ein wichtiger Knochen im Kn\xF6chel. Er verbindet
      das Bein mit dem Fu\xDF und sorgt f\xFCr fl\xFCssige Bewegungen beim Gehen."
    francais: "L\u2019astragale est un os important de la cheville. Il relie la jambe
      au pied et permet un mouvement fluide pendant la marche."
    italiano: "L\u2019astragalo \xE8 un importante osso della caviglia. Aiuta a collegare
      la gamba al piede e permette un movimento fluido mentre si cammina."
  - key: BONE_SCAPULA_NAME
    english: Scapula
    deutsch: Scapula
    francais: Scapula
    italiano: Scapola
  - key: BONE_SCAPULA_DESC
    english: The scapula is also called the shoulder blade. It helps the arms move
      and connects the arm to the body.
    deutsch: "Die Scapula wird auch Schulterblatt genannt. Sie hilft den Armen bei
      der Bewegung und verbindet den Arm mit dem K\xF6rper."
    francais: "La scapula est aussi appel\xE9e omoplate. Elle aide les bras \xE0
      bouger et relie le bras au corps.\t"
    italiano: "La scapola \xE8 chiamata anche spalla ossea o scapola. Aiuta le braccia
      a muoversi e collega il braccio al corpo."
  - key: TITLE_SUBTITLE
    english: Bones of Meaning
    deutsch: Knochen der Bedeutung
    francais: Les os du sens
    italiano: Ossa di significato
  - key: AUDIO
    english: AUDIO
    deutsch: AUDIO
    francais: AUDIO
    italiano: AUDIO
  - key: SETTINGS_SFX
    english: SFX
    deutsch: SFX
    francais: EFFETS
    italiano: EFFETTI
  - key: SETTINGS_MUSIC
    english: MUSIC
    deutsch: MUSIK
    francais: MUSIQUE
    italiano: MUSICA
  - key: LANGUAGE
    english: LANGUAGE
    deutsch: SPRACHE
    francais: LANGUE
    italiano: LINGUA
  - key: SETTINGS_CURRENT_SELECTION
    english: 'CURRENT:'
    deutsch: 'AKTUELL:'
    francais: 'ACTUEL :'
    italiano: 'ATTUALE:'
  - key: CHARACTER
    english: CHARACTER
    deutsch: CHARAKTER
    francais: PERSONNAGE
    italiano: PERSONAGGIO
  - key: SETTINGS_MALE
    english: MALE
    deutsch: "M\xC4NNLICH"
    francais: MASCULIN
    italiano: MASCHILE
  - key: SETTINGS_FEMALE
    english: FEMALE
    deutsch: WEIBLICH
    francais: "F\xC9MININ"
    italiano: FEMMINILE
  - key: LANGUAGE_SWITCH
    english: ENGLISH
    deutsch: DEUTSCH
    francais: "FRAN\xC7AIS"
    italiano: ITALIANO
  - key: LEVEL
    english: LEVEL
    deutsch: LEVEL
    francais: NIVEAU
    italiano: LIVELLO
  - key: CHAPTER
    english: CHAPTER
    deutsch: KAPITEL
    francais: CHAPITRE
    italiano: CAPITOLO
  - key: STORYLINE
    english: STORYLINE
    deutsch: GESCHICHTE
    francais: HISTOIRE
    italiano: STORIA
  - key: SKELETON_LENGTH_ESTIMATE
    english: 'Estimated body length: 25 cm'
    deutsch: "Gesch\xE4tzte K\xF6rperl\xE4nge: 25 cm"
    francais: "Longueur corporelle estim\xE9e : 25 cm"
    italiano: 'Lunghezza corporea stimata: 25 cm'
  - key: COMING_SOON
    english: COMING SOON
    deutsch: KOMMT BALD
    francais: "BIENT\xD4T"
    italiano: PROSSIMAMENTE
  - key: REWARDS
    english: REWARDS
    deutsch: BELOHNUNGEN
    francais: "R\xC9COMPENSES"
    italiano: RICOMPENSE
  - key: DETAILS
    english: DETAILS
    deutsch: INFOS
    francais: "D\xC9TAILS"
    italiano: DETTAGLI
  - key: SKIP_DIALOGUE
    english: SKIP DIALOGUE
    deutsch: "DIALOG \xDCBERSPRINGEN"
    francais: PASSER LE DIALOGUE
    italiano: SALTA DIALOGO
  - key: TIME_RAN_OUT
    english: TIME RAN OUT!
    deutsch: ZEIT ABGELAUFEN!
    francais: "TEMPS \xC9COUL\xC9 !"
    italiano: TEMPO SCADUTO!
  - key: RETRY
    english: RETRY
    deutsch: ERNEUT VERSUCHEN
    francais: "R\xC9ESSAYER"
    italiano: RIPROVA
  - key: MAIN_MENU
    english: MAIN MENU
    deutsch: "HAUPTMEN\xDC"
    francais: MENU PRINCIPAL
    italiano: MENU PRINCIPALE
  - key: FAIL_DESC_NIBBLES
    english: "Oh no! Time ran out before you could help Nibbles complete the discovery.
      \n\nTry again and help Darwin finish the bone puzzle!"
    deutsch: "Oh nein! Die Zeit ist abgelaufen, bevor du Nibbles bei der Entdeckung
      helfen konntest.\n\nVersuch es noch einmal und hilf Darwin, das Knochenr\xE4tsel
      zu l\xF6sen!"
    francais: "Oh non ! Le temps est \xE9coul\xE9 avant que tu puisses aider Nibbles
      \xE0 terminer la d\xE9couverte.\n\nR\xE9essaie et aide Darwin \xE0 r\xE9soudre
      le puzzle des os !"
    italiano: "Oh no! Il tempo \xE8 scaduto prima che tu potessi aiutare Nibbles
      a completare la scoperta.\n\nRiprova e aiuta Darwin a risolvere il puzzle delle
      ossa!"
  - key: FAIL_DESC_YETI
    english: 'Oh no! Time ran out before you could help Yeti solve the movement clues.


      Try
      again and match the bones before the timer ends!'
    deutsch: 'Oh nein! Die Zeit ist abgelaufen, bevor du Yeti bei den Bewegungshinweisen
      helfen konntest.


      Versuch es noch einmal und ordne die Knochen zu, bevor
      die Zeit endet!'
    francais: "Oh non ! Le temps est \xE9coul\xE9 avant que tu puisses aider Yeti
      \xE0 r\xE9soudre les indices de mouvement.\n\nR\xE9essaie et associe les os
      avant la fin du temps !"
    italiano: "Oh no! Il tempo \xE8 scaduto prima che tu potessi aiutare Yeti a risolvere
      gli indizi sul movimento.\n\nRiprova e abbina le ossa prima che il timer finisca!"
  - key: FAIL_DESC_ACHILLES
    english: "Oh no! Time ran out before you could help Achilles uncover the ancient
      bone clue. \n\nTry again and complete the challenge!"
    deutsch: 'Oh nein! Die Zeit ist abgelaufen, bevor du Achilles helfen konntest,
      den alten Knochenhinweis zu entdecken.


      Versuch es noch einmal und meistere
      die Herausforderung!'
    francais: "Oh non ! Le temps est \xE9coul\xE9 avant que tu puisses aider Achille
      \xE0 d\xE9couvrir l\u2019ancien indice osseux.\n\nR\xE9essaie et termine le
      d\xE9fi !"
    italiano: "Oh no! Il tempo \xE8 scaduto prima che tu potessi aiutare Achille
      a scoprire l\u2019antico indizio osseo.\n\nRiprova e completa la sfida!"
  - key: DIALOGUE_STAGE1_PRE_001
    english: 'Darwin: Our first journey begins in the Late Triassic, more than 200
      million years ago.'
    deutsch: "Darwin: Unsere erste Reise beginnt in der sp\xE4ten Trias, vor mehr
      als 200 Millionen Jahren."
    francais: "Darwin : Notre premier voyage commence au Trias sup\xE9rieur, il y
      a plus de 200 millions d\u2019ann\xE9es."
    italiano: "Darwin: Il nostro primo viaggio inizia nel Triassico superiore, pi\xF9
      di 200 milioni di anni fa."
  - key: DIALOGUE_STAGE1_PRE_002
    english: 'Player: That is really far back! What are we looking for?'
    deutsch: 'Spieler: Das ist wirklich sehr lange her! Wonach suchen wir?'
    francais: "Joueur : C\u2019est vraiment tr\xE8s loin dans le pass\xE9 ! Que cherchons-nous
      ?"
    italiano: "Giocatore: \xC8 davvero molto indietro nel tempo! Che cosa stiamo
      cercando?"
  - key: DIALOGUE_STAGE1_PRE_003
    english: 'Darwin: A tiny mammal-like creature called Nibbles. Its bones can teach
      us how early mammals were built.'
    deutsch: "Darwin: Ein winziges s\xE4ugetier\xE4hnliches Wesen namens Nibbles.
      Seine Knochen k\xF6nnen uns zeigen, wie fr\xFChe S\xE4ugetiere aufgebaut waren."
    francais: "Darwin : Une petite cr\xE9ature semblable \xE0 un mammif\xE8re, appel\xE9e
      Nibbles. Ses os peuvent nous apprendre comment les premiers mammif\xE8res \xE9taient
      construits."
    italiano: "Darwin: Una piccola creatura simile a un mammifero chiamata Nibbles.
      Le sue ossa possono insegnarci com\u2019erano fatti i primi mammiferi."
  - key: DIALOGUE_STAGE1_PRE_004
    english: 'Musowl: Hoo! Small bones can hide big discoveries!'
    deutsch: "Musowl: Huhu! Kleine Knochen k\xF6nnen gro\xDFe Entdeckungen verbergen!"
    francais: "Musowl : Hou hou ! De petits os peuvent cacher de grandes d\xE9couvertes
      !"
    italiano: 'Musowl: Uh uh! Piccole ossa possono nascondere grandi scoperte!'
  - key: DIALOGUE_STAGE1_PRE_005
    english: 'Darwin: Your task is to rebuild the skeleton by placing each bone in
      the correct slot.'
    deutsch: 'Darwin: Deine Aufgabe ist es, das Skelett wieder aufzubauen, indem
      du jeden Knochen an die richtige Stelle setzt.'
    francais: "Darwin : Ta mission est de reconstruire le squelette en pla\xE7ant
      chaque os au bon endroit."
    italiano: "Darwin: Il tuo compito \xE8 ricostruire lo scheletro mettendo ogni
      osso nello spazio corretto."
  - key: DIALOGUE_STAGE1_PRE_006
    english: 'Player: So I need to look carefully at the shapes?'
    deutsch: 'Spieler: Also muss ich genau auf die Formen achten?'
    francais: 'Joueur : Donc je dois bien observer les formes ?'
    italiano: 'Giocatore: Quindi devo osservare attentamente le forme?'
  - key: DIALOGUE_STAGE1_PRE_007
    english: 'Darwin: Exactly. Bones are clues. Their size, shape, and position tell
      us how an animal lived and moved.'
    deutsch: "Darwin: Genau. Knochen sind Hinweise. Ihre Gr\xF6\xDFe, Form und Position
      erz\xE4hlen uns, wie ein Tier lebte und sich bewegte."
    francais: "Darwin : Exactement. Les os sont des indices. Leur taille, leur forme
      et leur position nous racontent comment un animal vivait et se d\xE9pla\xE7ait."
    italiano: 'Darwin: Esatto. Le ossa sono indizi. La loro dimensione, forma e posizione
      ci raccontano come viveva e si muoveva un animale.'
  - key: DIALOGUE_STAGE1_PRE_008
    english: 'Musowl: Hoo! Help Nibbles come back together!'
    deutsch: 'Musowl: Huhu! Hilf Nibbles, wieder ganz zu werden!'
    francais: "Musowl : Hou hou ! Aide Nibbles \xE0 se reconstituer !"
    italiano: 'Musowl: Uh uh! Aiuta Nibbles a tornare intero!'
  - key: DIALOGUE_STAGE1_POST_001
    english: 'Darwin: Excellent work! Nibbles is whole again.'
    deutsch: "Darwin: Hervorragende Arbeit! Nibbles ist wieder vollst\xE4ndig."
    francais: 'Darwin : Excellent travail ! Nibbles est de nouveau complet.'
    italiano: "Darwin: Ottimo lavoro! Nibbles \xE8 di nuovo completo."
  - key: DIALOGUE_STAGE1_POST_002
    english: 'Player: The bones were like puzzle pieces, but they also had meaning.'
    deutsch: 'Spieler: Die Knochen waren wie Puzzleteile, aber sie hatten auch eine
      Bedeutung.'
    francais: "Joueur : Les os \xE9taient comme des pi\xE8ces de puzzle, mais ils
      avaient aussi une signification."
    italiano: 'Giocatore: Le ossa erano come pezzi di un puzzle, ma avevano anche
      un significato.'
  - key: DIALOGUE_STAGE1_POST_003
    english: 'Darwin: Precisely. When scientists rebuild a skeleton, they learn about
      body size, posture, and movement.'
    deutsch: "Darwin: Ganz genau. Wenn Wissenschaftler ein Skelett rekonstruieren,
      lernen sie etwas \xFCber K\xF6rpergr\xF6\xDFe, Haltung und Bewegung."
    francais: "Darwin : Pr\xE9cis\xE9ment. Quand les scientifiques reconstruisent
      un squelette, ils apprennent des choses sur la taille du corps, la posture
      et le mouvement."
    italiano: 'Darwin: Precisamente. Quando gli scienziati ricostruiscono uno scheletro,
      imparano informazioni sulla dimensione del corpo, la postura e il movimento.'
  - key: DIALOGUE_STAGE1_POST_004
    english: 'Musowl: Hoo! A fossil is not just old. It is evidence!'
    deutsch: 'Musowl: Huhu! Ein Fossil ist nicht nur alt. Es ist ein Beweis!'
    francais: "Musowl : Hou hou ! Un fossile n\u2019est pas seulement vieux. C\u2019est
      une preuve !"
    italiano: "Musowl: Uh uh! Un fossile non \xE8 solo antico. \xC8 una prova!"
  - key: DIALOGUE_STAGE1_POST_005
    english: "Darwin: You have earned Nibbles\u2019 discovery card. Our next mission
      will ask a different question: what are bones made to do?"
    deutsch: "Darwin: Du hast Nibbles\u2019 Entdeckungskarte verdient. Unsere n\xE4chste
      Mission stellt eine andere Frage: Wozu sind Knochen da?"
    francais: "Darwin : Tu as gagn\xE9 la carte de d\xE9couverte de Nibbles. Notre
      prochaine mission posera une autre question : \xE0 quoi servent les os ?"
    italiano: "Darwin: Hai guadagnato la carta scoperta di Nibbles. La nostra prossima
      missione far\xE0 una domanda diversa: a cosa servono le ossa?"
  - key: DIALOGUE_STAGE1_POST_006
    english: 'Musowl: Hoo! The Chrono-Engine is ready for the next journey!'
    deutsch: "Musowl: Huhu! Die Chrono-Maschine ist bereit f\xFCr die n\xE4chste
      Reise!"
    francais: "Musowl : Hou hou ! Le Chrono-Moteur est pr\xEAt pour le prochain voyage
      !"
    italiano: "Musowl: Uh uh! Il Chrono-Motore \xE8 pronto per il prossimo viaggio!"
  - key: DIALOGUE_STAGE2_PRE_001
    english: 'Darwin: Our next signal comes from a cold ancient landscape.'
    deutsch: "Darwin: Unser n\xE4chstes Signal kommt aus einer kalten, uralten Landschaft."
    francais: "Darwin : Notre prochain signal vient d\u2019un paysage ancien et froid."
    italiano: 'Darwin: Il nostro prossimo segnale arriva da un antico paesaggio freddo.'
  - key: DIALOGUE_STAGE2_PRE_002
    english: 'Player: Is that where Yeti lives?'
    deutsch: 'Spieler: Lebt dort Yeti?'
    francais: "Joueur : C\u2019est l\xE0 que vit Yeti ?"
    italiano: "Giocatore: \xC8 l\xEC che vive Yeti?"
  - key: DIALOGUE_STAGE2_PRE_003
    english: 'Darwin: Yes. Yeti needs help understanding how different bones support
      movement.'
    deutsch: "Darwin: Ja. Yeti braucht Hilfe, um zu verstehen, wie verschiedene Knochen
      Bewegung unterst\xFCtzen."
    francais: "Darwin : Oui. Yeti a besoin d\u2019aide pour comprendre comment diff\xE9rents
      os soutiennent le mouvement."
    italiano: "Darwin: S\xEC. Yeti ha bisogno di aiuto per capire come diverse ossa
      sostengono il movimento."
  - key: DIALOGUE_STAGE2_PRE_004
    english: 'Musowl: Hoo! Not every bone has the same job!'
    deutsch: 'Musowl: Huhu! Nicht jeder Knochen hat dieselbe Aufgabe!'
    francais: "Musowl : Hou hou ! Tous les os n\u2019ont pas le m\xEAme r\xF4le !"
    italiano: 'Musowl: Uh uh! Non tutte le ossa hanno lo stesso compito!'
  - key: DIALOGUE_STAGE2_PRE_005
    english: 'Darwin: This time, do not only think about shape. Think about function.'
    deutsch: 'Darwin: Denk diesmal nicht nur an die Form. Denk auch an die Funktion.'
    francais: "Darwin : Cette fois, ne pense pas seulement \xE0 la forme. Pense aussi
      \xE0 la fonction."
    italiano: 'Darwin: Questa volta non pensare solo alla forma. Pensa anche alla
      funzione.'
  - key: DIALOGUE_STAGE2_PRE_006
    english: 'Player: Function means what the bone does?'
    deutsch: 'Spieler: Funktion bedeutet, was der Knochen macht?'
    francais: "Joueur : La fonction, c\u2019est ce que fait l\u2019os ?"
    italiano: "Giocatore: Funzione significa ci\xF2 che fa l\u2019osso?"
  - key: DIALOGUE_STAGE2_PRE_007
    english: 'Darwin: Exactly. Some bones support weight, some help with balance,
      and some guide motion.'
    deutsch: 'Darwin: Genau. Manche Knochen tragen Gewicht, manche helfen beim Gleichgewicht,
      und manche lenken Bewegungen.'
    francais: "Darwin : Exactement. Certains os portent le poids, d\u2019autres aident
      \xE0 garder l\u2019\xE9quilibre, et d\u2019autres guident le mouvement."
    italiano: "Darwin: Esatto. Alcune ossa sostengono il peso, altre aiutano l\u2019equilibrio
      e altre guidano il movimento."
  - key: DIALOGUE_STAGE2_PRE_008
    english: 'Musowl: Hoo! Match the clues and help Yeti move with confidence!'
    deutsch: 'Musowl: Huhu! Ordne die Hinweise zu und hilf Yeti, sich sicher zu bewegen!'
    francais: "Musowl : Hou hou ! Associe les indices et aide Yeti \xE0 bouger avec
      confiance !"
    italiano: 'Musowl: Uh uh! Abbina gli indizi e aiuta Yeti a muoversi con sicurezza!'
  - key: DIALOGUE_STAGE2_POST_001
    english: 'Darwin: Well done! You helped Yeti understand the movement clues.'
    deutsch: 'Darwin: Gut gemacht! Du hast Yeti geholfen, die Bewegungshinweise zu
      verstehen.'
    francais: "Darwin : Bien jou\xE9 ! Tu as aid\xE9 Yeti \xE0 comprendre les indices
      du mouvement."
    italiano: 'Darwin: Ben fatto! Hai aiutato Yeti a capire gli indizi del movimento.'
  - key: DIALOGUE_STAGE2_POST_002
    english: 'Player: I noticed that bones are not only shapes. They have jobs.'
    deutsch: 'Spieler: Ich habe gemerkt, dass Knochen nicht nur Formen sind. Sie
      haben Aufgaben.'
    francais: "Joueur : J\u2019ai remarqu\xE9 que les os ne sont pas seulement des
      formes. Ils ont des r\xF4les."
    italiano: 'Giocatore: Ho notato che le ossa non sono solo forme. Hanno dei compiti.'
  - key: DIALOGUE_STAGE2_POST_003
    english: 'Darwin: That is one of the most important ideas in anatomy: form and
      function belong together.'
    deutsch: "Darwin: Das ist eine der wichtigsten Ideen in der Anatomie: Form und
      Funktion geh\xF6ren zusammen."
    francais: "Darwin : C\u2019est l\u2019une des id\xE9es les plus importantes en
      anatomie : la forme et la fonction vont ensemble."
    italiano: "Darwin: Questa \xE8 una delle idee pi\xF9 importanti dell\u2019anatomia:
      forma e funzione vanno insieme."
  - key: DIALOGUE_STAGE2_POST_004
    english: 'Musowl: Hoo! A strong shape can tell us how a body moves!'
    deutsch: "Musowl: Huhu! Eine starke Form kann uns zeigen, wie sich ein K\xF6rper
      bewegt!"
    francais: 'Musowl : Hou hou ! Une forme solide peut nous montrer comment un corps
      bouge !'
    italiano: "Musowl: Uh uh! Una forma robusta pu\xF2 mostrarci come si muove un
      corpo!"
  - key: DIALOGUE_STAGE2_POST_005
    english: "Darwin: You have earned Yeti\u2019s discovery card. Now we travel from
      anatomy into history."
    deutsch: 'Darwin: Du hast Yetis Entdeckungskarte verdient. Jetzt reisen wir von
      der Anatomie in die Geschichte.'
    francais: "Darwin : Tu as gagn\xE9 la carte de d\xE9couverte de Yeti. Maintenant,
      nous passons de l\u2019anatomie \xE0 l\u2019histoire."
    italiano: "Darwin: Hai guadagnato la carta scoperta di Yeti. Ora viaggiamo dall\u2019anatomia
      alla storia."
  - key: DIALOGUE_STAGE2_POST_006
    english: 'Musowl: Hoo! The next clue comes from the ancient world!'
    deutsch: "Musowl: Huhu! Der n\xE4chste Hinweis kommt aus der antiken Welt!"
    francais: 'Musowl : Hou hou ! Le prochain indice vient du monde antique !'
    italiano: 'Musowl: Uh uh! Il prossimo indizio arriva dal mondo antico!'
  - key: DIALOGUE_STAGE3_PRE_001
    english: 'Darwin: Our final journey leads us to the ancient world.'
    deutsch: "Darwin: Unsere letzte Reise f\xFChrt uns in die antike Welt."
    francais: "Darwin : Notre dernier voyage nous m\xE8ne dans le monde antique."
    italiano: 'Darwin: Il nostro ultimo viaggio ci porta nel mondo antico.'
  - key: DIALOGUE_STAGE3_PRE_002
    english: 'Player: This place feels different. Are we still studying bones?'
    deutsch: "Spieler: Dieser Ort f\xFChlt sich anders an. Untersuchen wir immer
      noch Knochen?"
    francais: "Joueur : Cet endroit semble diff\xE9rent. \xC9tudions-nous encore
      les os ?"
    italiano: 'Giocatore: Questo luogo sembra diverso. Stiamo ancora studiando le
      ossa?'
  - key: DIALOGUE_STAGE3_PRE_003
    english: 'Darwin: Yes, but now bones also help us understand people, culture,
      and history.'
    deutsch: 'Darwin: Ja, aber jetzt helfen uns Knochen auch, Menschen, Kultur und
      Geschichte zu verstehen.'
    francais: "Darwin : Oui, mais maintenant les os nous aident aussi \xE0 comprendre
      les personnes, la culture et l\u2019histoire."
    italiano: "Darwin: S\xEC, ma ora le ossa ci aiutano anche a capire le persone,
      la cultura e la storia."
  - key: DIALOGUE_STAGE3_PRE_004
    english: 'Musowl: Hoo! Archaeology listens to objects from the past!'
    deutsch: "Musowl: Huhu! Arch\xE4ologie h\xF6rt den Dingen aus der Vergangenheit
      zu!"
    francais: "Musowl : Hou hou ! L\u2019arch\xE9ologie \xE9coute les objets du pass\xE9
      !"
    italiano: "Musowl: Uh uh! L\u2019archeologia ascolta gli oggetti del passato!"
  - key: DIALOGUE_STAGE3_PRE_005
    english: 'Darwin: You will examine larger bone structures, such as the skull
      and pelvis, as important clues.'
    deutsch: "Darwin: Du wirst gr\xF6\xDFere Knochenstrukturen untersuchen, zum Beispiel
      den Sch\xE4del und das Becken, als wichtige Hinweise."
    francais: "Darwin : Tu vas examiner de grandes structures osseuses, comme le
      cr\xE2ne et le bassin, qui sont des indices importants."
    italiano: "Darwin: Esaminerai strutture ossee pi\xF9 grandi, come il cranio e
      il bacino, come indizi importanti."
  - key: DIALOGUE_STAGE3_PRE_006
    english: 'Player: So they are not just single bones. They are structured objects
      with meaning?'
    deutsch: 'Spieler: Also sind sie nicht nur einzelne Knochen. Sie sind strukturierte
      Objekte mit Bedeutung?'
    francais: "Joueur : Donc ce ne sont pas seulement des os isol\xE9s. Ce sont des
      objets structur\xE9s qui ont du sens ?"
    italiano: 'Giocatore: Quindi non sono solo singole ossa. Sono oggetti strutturati
      con un significato?'
  - key: DIALOGUE_STAGE3_PRE_007
    english: 'Darwin: Correct. In archaeology, every structure and object must be
      studied carefully and respectfully.'
    deutsch: "Darwin: Richtig. In der Arch\xE4ologie m\xFCssen jede Struktur und
      jedes Objekt sorgf\xE4ltig und respektvoll untersucht werden."
    francais: "Darwin : Exactement. En arch\xE9ologie, chaque structure et chaque
      objet doivent \xEAtre \xE9tudi\xE9s avec soin et respect."
    italiano: 'Darwin: Esatto. In archeologia, ogni struttura e ogni oggetto devono
      essere studiati con attenzione e rispetto.'
  - key: DIALOGUE_STAGE3_PRE_008
    english: 'Musowl: Hoo! Help Achilles uncover the ancient clue!'
    deutsch: 'Musowl: Huhu! Hilf Achilles, den antiken Hinweis zu entdecken!'
    francais: "Musowl : Hou hou ! Aide Achille \xE0 d\xE9couvrir l\u2019indice antique
      !"
    italiano: "Musowl: Uh uh! Aiuta Achille a scoprire l\u2019indizio antico!"
  - key: DIALOGUE_STAGE3_POST_001
    english: "Darwin: Wonderful work. Achilles\u2019 ancient clue has been uncovered."
    deutsch: "Darwin: Wunderbare Arbeit. Achilles\u2019 antiker Hinweis wurde entdeckt."
    francais: "Darwin : Merveilleux travail. L\u2019indice antique d\u2019Achille
      a \xE9t\xE9 d\xE9couvert."
    italiano: "Darwin: Ottimo lavoro. L\u2019antico indizio di Achille \xE8 stato
      scoperto."
  - key: DIALOGUE_STAGE3_POST_002
    english: 'Player: This mission felt different. The bones told a human story.'
    deutsch: "Spieler: Diese Mission f\xFChlte sich anders an. Die Knochen erz\xE4hlten
      eine menschliche Geschichte."
    francais: "Joueur : Cette mission semblait diff\xE9rente. Les os racontaient
      une histoire humaine."
    italiano: 'Giocatore: Questa missione sembrava diversa. Le ossa raccontavano
      una storia umana.'
  - key: DIALOGUE_STAGE3_POST_003
    english: 'Darwin: Exactly. Anatomy helps us understand the body, while archaeology
      helps us understand life, culture, and the past.'
    deutsch: "Darwin: Genau. Anatomie hilft uns, den K\xF6rper zu verstehen, w\xE4hrend
      Arch\xE4ologie uns hilft, Leben, Kultur und die Vergangenheit zu verstehen."
    francais: "Darwin : Exactement. L\u2019anatomie nous aide \xE0 comprendre le
      corps, tandis que l\u2019arch\xE9ologie nous aide \xE0 comprendre la vie, la
      culture et le pass\xE9."
    italiano: "Darwin: Esatto. L\u2019anatomia ci aiuta a capire il corpo, mentre
      l\u2019archeologia ci aiuta a capire la vita, la cultura e il passato."
  - key: DIALOGUE_STAGE3_POST_004
    english: 'Musowl: Hoo! Bones can teach science and history together!'
    deutsch: "Musowl: Huhu! Knochen k\xF6nnen Wissenschaft und Geschichte zusammen
      lehren!"
    francais: "Musowl : Hou hou ! Les os peuvent enseigner la science et l\u2019histoire
      ensemble !"
    italiano: 'Musowl: Uh uh! Le ossa possono insegnare scienza e storia insieme!'
  - key: DIALOGUE_STAGE3_POST_005
    english: "Darwin: You have completed the Chrono-Scientist prototype and earned
      Achilles\u2019 discovery card."
    deutsch: "Darwin: Du hast den Chrono-Scientist-Prototyp abgeschlossen und Achilles\u2019
      Entdeckungskarte verdient."
    francais: "Darwin : Tu as termin\xE9 le prototype Chrono-Scientist et gagn\xE9
      la carte de d\xE9couverte d\u2019Achille."
    italiano: 'Darwin: Hai completato il prototipo di Chrono-Scientist e guadagnato
      la carta scoperta di Achille.'
  - key: DIALOGUE_STAGE3_POST_006
    english: 'Musowl: Hoo! A true bone detective returns to the lab!'
    deutsch: "Musowl: Huhu! Ein echter Knochendetektiv kehrt ins Labor zur\xFCck!"
    francais: "Musowl : Hou hou ! Un vrai d\xE9tective des os retourne au laboratoire
      !"
    italiano: 'Musowl: Uh uh! Un vero detective delle ossa ritorna in laboratorio!'
  - key: FRONT_PAGE
    english: FRONT PAGE
    deutsch: VORDERSEITE
    francais: PAGE AVANT
    italiano: PAGINA FRONTALE
  - key: BACK_PAGE
    english: BACK PAGE
    deutsch: "R\xDCCKSEITE"
    francais: "PAGE ARRI\xC8RE"
    italiano: PAGINA POSTERIORE
  - key: FLIP
    english: FLIP
    deutsch: UMDREHEN
    francais: RETOURNER
    italiano: GIRA
  - key: CARD_RANK
    english: CARD RANK
    deutsch: KARTENRANG
    francais: RANG DE CARTE
    italiano: GRADO CARTA
  - key: GOLD
    english: GOLD
    deutsch: GOLD
    francais: OR
    italiano: ORO
  - key: SILVER
    english: SILVER
    deutsch: SILBER
    francais: ARGENT
    italiano: ARGENTO
  - key: BRONZE
    english: BRONZE
    deutsch: BRONZE
    francais: BRONZE
    italiano: BRONZO
  - key: ASTRAGALOS_BADGE
    english: Astragalos Badge
    deutsch: Astragalos-Abzeichen
    francais: 'Badge Astragale '
    italiano: Distintivo Astragalo
  - key: REWARD_NIBBLES_FRONT
    english: '<b>Character:</b> Nibbles

      <b>Represents:</b> Brasilodon quadrangularis

      <b>Era:</b>
      Late Triassic

      <b>Time:</b> about 225 million years ago

      <b>Status:</b>
      Extinct

      <b>Size:</b> roughly 20 cm long'
    deutsch: "<b>Figur:</b> Nibbles\n<b>Repr\xE4sentiert:</b> Brasilodon quadrangularis\n<b>Zeitalter:</b>
      Sp\xE4te Trias\n<b>Zeit:</b> vor etwa 225 Millionen Jahren\n<b>Status:</b>
      Ausgestorben\n<b>Gr\xF6\xDFe:</b> ungef\xE4hr 20 cm lang"
    francais: "<b>Personnage :</b> Nibbles\n<b>Repr\xE9sente :</b> Brasilodon quadrangularis\n<b>\xC9poque
      :</b> Trias sup\xE9rieur\n<b>Temps :</b> il y a environ 225 millions d\u2019ann\xE9es\n<b>Statut
      :</b> \xC9teint\n<b>Taille :</b> environ 20 cm de long"
    italiano: '<b>Personaggio:</b> Nibbles

      <b>Rappresenta:</b> Brasilodon
      quadrangularis

      <b>Epoca:</b> Triassico superiore

      <b>Tempo:</b>
      circa 225 milioni di anni fa

      <b>Stato:</b> Estinto

      <b>Dimensione:</b>
      circa 20 cm di lunghezza'
  - key: REWARD_NIBBLES_BACK
    english: "In this mission, you learned the names of important bones and bone
      structures by rebuilding parts of Nibbles\u2019 skeleton."
    deutsch: "In dieser Mission hast du die Namen wichtiger Knochen und Knochenstrukturen
      gelernt, indem du Teile von Nibbles\u2019 Skelett wieder zusammengesetzt hast."
    francais: "Dans cette mission, tu as appris les noms d\u2019os et de structures
      osseuses importantes en reconstruisant des parties du squelette de Nibbles."
    italiano: In questa missione hai imparato i nomi di ossa e strutture ossee importanti
      ricostruendo parti dello scheletro di Nibbles.
  - key: REWARD_YETI_FRONT
    english: '<b>Character:</b> Yeti

      <b>Represents:</b> Australopithecus

      <b>Era:</b>
      Pliocene to early Pleistocene

      <b>Time:</b> about 4.4 to 1.4 million
      years ago

      <b>Status:</b> Extinct

      <b>Size:</b> 1 to 1.5 meters
      tall'
    deutsch: "<b>Figur:</b> Yeti\n<b>Repr\xE4sentiert:</b> Australopithecus\n<b>Zeitalter:</b>
      Plioz\xE4n bis fr\xFChes Pleistoz\xE4n\n<b>Zeit:</b> vor etwa 4,4 bis 1,4 Millionen
      Jahren\n<b>Status:</b> Ausgestorben\n<b>Gr\xF6\xDFe:</b> 1 bis 1,5 Meter gro\xDF"
    francais: "<b>Personnage :</b> Yeti\n<b>Repr\xE9sente :</b> Australopithecus\n<b>\xC9poque
      :</b> Plioc\xE8ne au d\xE9but du Pl\xE9istoc\xE8ne\n<b>Temps :</b> il y a environ
      4,4 \xE0 1,4 million d\u2019ann\xE9es\n<b>Statut :</b> \xC9teint\n<b>Taille
      :</b> 1 \xE0 1,5 m\xE8tre de haut"
    italiano: '<b>Personaggio:</b> Yeti

      <b>Rappresenta:</b> Australopithecus

      <b>Epoca:</b>
      dal Pliocene al primo Pleistocene

      <b>Tempo:</b> circa 4,4-1,4 milioni
      di anni fa

      <b>Stato:</b> Estinto

      <b>Dimensione:</b> alto da 1
      a 1,5 metri'
  - key: REWARD_YETI_BACK
    english: "In this mission, you matched each bone or structure by its function.
      Bones are not only shapes \u2014 they help bodies move, balance, and stand."
    deutsch: "In dieser Mission hast du jeden Knochen oder jede Struktur ihrer Funktion
      zugeordnet. Knochen sind nicht nur Formen \u2014 sie helfen K\xF6rpern, sich
      zu bewegen, das Gleichgewicht zu halten und zu stehen."
    francais: "Dans cette mission, tu as associ\xE9 chaque os ou structure \xE0 sa
      fonction. Les os ne sont pas seulement des formes \u2014 ils aident les corps
      \xE0 bouger, \xE0 garder l\u2019\xE9quilibre et \xE0 se tenir debout."
    italiano: "In questa missione hai abbinato ogni osso o struttura alla sua funzione.
      Le ossa non sono solo forme \u2014 aiutano i corpi a muoversi, a mantenere
      l\u2019equilibrio e a stare in piedi."
  - key: REWARD_ACHILLES_FRONT
    english: '<b>Character:</b> Achilles

      <b>Represents:</b> Homo sapiens

      <b>Era:</b>
      Ancient Greece / Spartan era

      <b>Time:</b> about 2500 years ago

      <b>Status:</b>
      Living species

      <b>Size:</b> around 1.7 meters tall'
    deutsch: "<b>Figur:</b> Achilles\n<b>Repr\xE4sentiert:</b> Homo sapiens\n<b>Zeitalter:</b>
      Antikes Griechenland / spartanische \xC4ra\n<b>Zeit:</b> vor etwa 2500 Jahren\n<b>Status:</b>
      Lebende Art\n<b>Gr\xF6\xDFe:</b> ungef\xE4hr 1,7 Meter gro\xDF"
    francais: "<b>Personnage :</b> Achille\n<b>Repr\xE9sente :</b> Homo sapiens\n<b>\xC9poque
      :</b> Gr\xE8ce antique / \xE9poque spartiate\n<b>Temps :</b> il y a environ
      2500 ans\n<b>Statut :</b> Esp\xE8ce vivante\n<b>Taille :</b> environ 1,7 m\xE8tre
      de haut"
    italiano: '<b>Personaggio:</b> Achille

      <b>Rappresenta:</b> Homo sapiens

      <b>Epoca:</b>
      Antica Grecia / era spartana

      <b>Tempo:</b> circa 2500 anni fa

      <b>Stato:</b>
      Specie vivente

      <b>Dimensione:</b> circa 1,7 metri di altezza'
  - key: REWARD_ACHILLES_BACK
    english: In this mission, you decoded bone amulets by observing their shape and
      meaning. In archaeology, bones can become objects of memory, identity, belief,
      and culture.
    deutsch: "In dieser Mission hast du Knochenamulette entschl\xFCsselt, indem du
      ihre Form und Bedeutung beobachtet hast. In der Arch\xE4ologie k\xF6nnen Knochen
      zu Objekten der Erinnerung, Identit\xE4t, des Glaubens und der Kultur werden."
    francais: "Dans cette mission, tu as d\xE9cod\xE9 des amulettes d\u2019os en
      observant leur forme et leur signification. En arch\xE9ologie, les os peuvent
      devenir des objets de m\xE9moire, d\u2019identit\xE9, de croyance et de culture."
    italiano: "In questa missione hai decifrato amuleti d\u2019osso osservandone
      la forma e il significato. In archeologia, le ossa possono diventare oggetti
      di memoria, identit\xE0, credenza e cultura."
  - key: NIBBLES
    english: NIBBLES
    deutsch: NIBBLES
    francais: NIBBLES
    italiano: NIBBLES
  - key: YETI
    english: YETI
    deutsch: YETI
    francais: YETI
    italiano: YETI
  - key: ACHILLES
    english: ACHILLES
    deutsch: ACHILLES
    francais: ACHILLE
    italiano: ACHILLE
  - key: STAGE2_MISSION_TITLE
    english: PLEISTOCENE ERA
    deutsch: "PLEISTOZ\xC4N"
    francais: "PL\xC9ISTOC\xC8NE"
    italiano: PLEISTOCENE
  - key: STAGE2_MISSION_DESC
    english: Help an ancient human relative learn how bones help the body move.
    deutsch: "Hilf einem alten Verwandten des Menschen zu lernen, wie Knochen dem
      K\xF6rper bei der Bewegung helfen."
    francais: "Aide un ancien parent de l\u2019\xEAtre humain \xE0 comprendre comment
      les os aident le corps \xE0 bouger."
    italiano: "Aiuta un antico parente dell\u2019essere umano a capire come le ossa
      aiutano il corpo a muoversi."
  - key: STAGE2_ASSEMBLY_001
    english: Help Yeti match each bone to its function.
    deutsch: Hilf Yeti, jeden Knochen seiner Funktion zuzuordnen.
    francais: "Aide Yeti \xE0 associer chaque os \xE0 sa fonction."
    italiano: Aiuta Yeti ad abbinare ogni osso alla sua funzione.
  - key: STAGE2_ASSEMBLY_002
    english: 'Correct matches: {current}/{total}'
    deutsch: 'Richtige Zuordnungen: {current}/{total}'
    francais: 'Correspondances correctes : {current}/{total}'
    italiano: 'Abbinamenti corretti: {current}/{total}'
  - key: STAGE2_ASSEMBLY_003
    english: All bone functions matched!
    deutsch: Alle Knochenfunktionen zugeordnet!
    francais: "Toutes les fonctions des os sont associ\xE9es !"
    italiano: Tutte le funzioni delle ossa sono abbinate!
  - key: FUNCTION_SCAPULA
    english: Helps the shoulder move
    deutsch: Hilft der Schulter beim Bewegen
    francais: "Aide l\u2019\xE9paule \xE0 bouger"
    italiano: Aiuta la spalla a muoversi
  - key: FUNCTION_HUMERUS
    english: Strengthens the upper front leg
    deutsch: "St\xE4rkt das obere Vorderbein"
    francais: Renforce le haut de la patte avant
    italiano: Rinforza la parte alta della zampa anteriore
  - key: FUNCTION_FEMUR
    english: Powers the upper back leg
    deutsch: Gibt dem oberen Hinterbein Kraft
    francais: "Donne de la force au haut de la patte arri\xE8re"
    italiano: "D\xE0 forza alla parte alta della zampa posteriore"
  - key: FUNCTION_PELVIS
    english: Connects the spine to the legs
    deutsch: "Verbindet die Wirbels\xE4ule mit den Beinen"
    francais: "Relie la colonne vert\xE9brale aux jambes"
    italiano: Collega la colonna vertebrale alle gambe
  - key: FUNCTION_ASTRAGALOS
    english: Helps the ankle move smoothly
    deutsch: Hilft dem Sprunggelenk, sich geschmeidig zu bewegen
    francais: "Aide la cheville \xE0 bouger en douceur"
    italiano: Aiuta la caviglia a muoversi in modo fluido
  - key: FUNCTION_CRANIUM
    english: Protects the brain
    deutsch: "Sch\xFCtzt das Gehirn"
    francais: "Prot\xE8ge le cerveau"
    italiano: Protegge il cervello
  - key: STAGE2_COMPLETION_TITLE
    english: Level 5 Completed!
    deutsch: Level 5 abgeschlossen!
    francais: "Niveau 5 termin\xE9 !"
    italiano: Livello 5 completato!
  - key: STAGE2_COMPLETION_DESC
    english: Thank you! Now I understand how each bone helps the body move.
    deutsch: "Danke! Jetzt verstehe ich, wie jeder Knochen dem K\xF6rper bei der
      Bewegung hilft."
    francais: "Merci ! Maintenant, je comprends comment chaque os aide le corps \xE0
      bouger."
    italiano: Grazie! Ora capisco come ogni osso aiuta il corpo a muoversi.
  - key: STAGE3_MISSION_TITLE
    english: SPARTAN ERA
    deutsch: SPARTANISCHE ZEIT
    francais: "\xC9POQUE SPARTIATE"
    italiano: EPOCA SPARTANA
  - key: STAGE3_MISSION_DESC
    english: Look at the bone amulets and find out what each one represents.
    deutsch: "Betrachte die Knochenamulette und finde heraus, wof\xFCr jedes steht."
    francais: "Observe les amulettes d\u2019os et d\xE9couvre ce que chacune repr\xE9sente."
    italiano: "Osserva gli amuleti d\u2019osso e scopri che cosa rappresenta ciascuno."
  - key: STAGE3_ASSEMBLY_001
    english: Help Achilles decode the bone amulets.
    deutsch: "Hilf Achilles, die Knochenamulette zu entschl\xFCsseln."
    francais: "Aide Achilles \xE0 d\xE9coder les amulettes d\u2019os."
    italiano: "Aiuta Achilles a decifrare gli amuleti d\u2019osso."
  - key: STAGE3_ASSEMBLY_002
    english: 'Amulets decoded: {current}/{total}'
    deutsch: "Entschl\xFCsselte Amulette: {current}/{total}"
    francais: "Amulettes d\xE9cod\xE9es : {current}/{total}"
    italiano: 'Amuleti decifrati: {current}/{total}'
  - key: STAGE3_ASSEMBLY_003
    english: All amulets decoded!
    deutsch: "Alle Amulette entschl\xFCsselt!"
    francais: "Toutes les amulettes sont d\xE9cod\xE9es !"
    italiano: Tutti gli amuleti sono stati decifrati!
  - key: STAGE3_COMPLETION_TITLE
    english: Level 9 Completed!
    deutsch: Level 9 abgeschlossen!
    francais: "Niveau 9 termin\xE9 !"
    italiano: Livello 9 completato!
  - key: STAGE3_COMPLETION_DESC
    english: Well done! You uncovered the meaning hidden inside the bone amulets.
    deutsch: Gut gemacht! Du hast die Bedeutung entdeckt, die in den Knochenamuletten
      verborgen war.
    francais: "Bien jou\xE9 ! Tu as d\xE9couvert le sens cach\xE9 dans les amulettes
      d\u2019os."
    italiano: "Ben fatto! Hai scoperto il significato nascosto negli amuleti d\u2019osso."
  - key: STAGE3_CLUE_SCAPULA
    english: Shield of the Shoulder
    deutsch: Schild der Schulter
    francais: "Bouclier de l\u2019\xE9paule"
    italiano: Scudo della spalla
  - key: STAGE3_CLUE_HUMERUS
    english: Strength of the Arm
    deutsch: Kraft des Arms
    francais: Force du bras
    italiano: Forza del braccio
  - key: STAGE3_CLUE_FEMUR
    english: Pillar of the Warrior
    deutsch: "S\xE4ule des Kriegers"
    francais: Pilier du guerrier
    italiano: Pilastro del guerriero
  - key: STAGE3_CLUE_PELVIS
    english: Balance Core
    deutsch: Zentrum des Gleichgewichts
    francais: "Centre de l\u2019\xE9quilibre"
    italiano: "Centro dell\u2019equilibrio"
  - key: STAGE3_CLUE_ASTRAGALOS
    english: Step of Fate
    deutsch: Schritt des Schicksals
    francais: Pas du destin
    italiano: Passo del destino
  - key: STAGE3_CLUE_CRANIUM
    english: Guardian of Thought
    deutsch: "W\xE4chter des Denkens"
    francais: "Gardien de la pens\xE9e"
    italiano: Guardiano del pensiero
  - key: STAGE3_AMULET_SCAPULA_DESC
    english: A flat bone rests on the upper back, guiding the shoulder as it moves...
    deutsch: "Ein flacher Knochen liegt am oberen R\xFCcken und f\xFChrt die Schulter
      bei der Bewegung..."
    francais: "Un os plat repose sur le haut du dos et guide l\u2019\xE9paule dans
      son mouvement..."
    italiano: Un osso piatto si trova nella parte alta della schiena e guida la spalla
      nel movimento...
  - key: STAGE3_AMULET_HUMERUS_DESC
    english: A strong upper bone carries force when a Spartan reaches, pushes, or
      strikes...
    deutsch: "Ein starker oberer Knochen tr\xE4gt Kraft, wenn ein Spartaner greift,
      dr\xFCckt oder schl\xE4gt..."
    francais: "Un os sup\xE9rieur solide porte la force quand un Spartiate atteint,
      pousse ou frappe..."
    italiano: Un forte osso superiore porta forza quando uno Spartano raggiunge,
      spinge o colpisce...
  - key: STAGE3_AMULET_FEMUR_DESC
    english: The mighty upper hind-leg bone holds the Spartan high and drives him
      forward.
    deutsch: "Der m\xE4chtige obere Knochen des Hinterbeins h\xE4lt den Spartaner
      aufrecht und treibt ihn voran."
    francais: "Le puissant os sup\xE9rieur de la patte arri\xE8re soutient le Spartiate
      et le pousse en avant."
    italiano: Il potente osso superiore della zampa posteriore sostiene lo Spartano
      e lo spinge in avanti.
  - key: STAGE3_AMULET_PELVIS_DESC
    english: Balance begins at the center, where the body is joined and steadied...
    deutsch: "Das Gleichgewicht beginnt in der Mitte, wo der K\xF6rper verbunden
      und gest\xFCtzt wird..."
    francais: "L\u2019\xE9quilibre commence au centre, l\xE0 o\xF9 le corps se relie
      et se stabilise..."
    italiano: "L\u2019equilibrio nasce al centro, dove il corpo si unisce e si stabilizza..."
  - key: STAGE3_AMULET_ASTRAGALOS_DESC
    english: "It seems Achilles\u2019 heel was not the only weak point; a small hidden
      bone carried part of the fate..."
    deutsch: "Es scheint, Achilles\u2019 Ferse war nicht die einzige Schwachstelle;
      ein kleiner verborgener Knochen trug einen Teil des Schicksals..."
    francais: "Il semble que le talon d\u2019Achilles n\u2019\xE9tait pas le seul
      point faible ; un petit os cach\xE9 portait une part du destin..."
    italiano: "Sembra che il tallone di Achilles non fosse l\u2019unico punto debole;
      un piccolo osso nascosto portava parte del destino..."
  - key: STAGE3_AMULET_CRANIUM_DESC
    english: Beneath the Spartan helmet, a hard case protects senses, memory, and
      command...
    deutsch: "Unter dem spartanischen Helm sch\xFCtzt eine harte H\xFClle Sinne,
      Erinnerung und Befehl..."
    francais: "Sous le casque spartiate, une bo\xEEte dure prot\xE8ge les sens, la
      m\xE9moire et le commandement..."
    italiano: "Sotto l\u2019elmo spartano, una custodia dura protegge i sensi, la
      memoria e il comando..."
  - key: REWARD_NIBBLES_BACK_ROW_CRANIUM
    english: "<b>Cranium / Skull</b> \u2014 protects the brain and shapes the head."
    deutsch: "<b>Cranium / Sch\xE4del</b> \u2014 sch\xFCtzt das Gehirn und formt
      den Kopf."
    francais: "<b>Cr\xE2ne / Skull</b> \u2014 prot\xE8ge le cerveau et forme la t\xEAte."
    italiano: "<b>Cranio / Skull</b> \u2014 protegge il cervello e d\xE0 forma alla
      testa."
  - key: REWARD_NIBBLES_BACK_ROW_SCAPULA
    english: "<b>Scapula / Shoulder blade</b> \u2014 connects the front limb to the
      body."
    deutsch: "<b>Scapula / Schulterblatt</b> \u2014 verbindet die vordere Gliedma\xDFe
      mit dem K\xF6rper."
    francais: "<b>Scapula / Omoplate</b> \u2014 relie le membre avant au corps."
    italiano: "<b>Scapola / Osso della spalla</b> \u2014 collega l\u2019arto anteriore
      al corpo."
  - key: REWARD_NIBBLES_BACK_ROW_HUMERUS
    english: "<b>Humerus / Upper arm bone</b> \u2014 helps the front limb move and
      support weight."
    deutsch: "<b>Humerus / Oberarmknochen</b> \u2014 hilft der vorderen Gliedma\xDFe,
      sich zu bewegen und Gewicht zu st\xFCtzen."
    francais: "<b>Hum\xE9rus / Os du bras sup\xE9rieur</b> \u2014 aide le membre
      avant \xE0 bouger et \xE0 soutenir le poids."
    italiano: "<b>Omero / Osso del braccio superiore</b> \u2014 aiuta l\u2019arto
      anteriore a muoversi e a sostenere il peso."
  - key: REWARD_NIBBLES_BACK_ROW_PELVIS
    english: "<b>Pelvis / Hip bone structure</b> \u2014 connects the body to the
      hind limbs."
    deutsch: "<b>Becken / H\xFCftstruktur</b> \u2014 verbindet den K\xF6rper mit
      den hinteren Gliedma\xDFen."
    francais: "<b>Bassin / Structure de la hanche</b> \u2014 relie le corps aux membres
      arri\xE8re."
    italiano: "<b>Bacino / Struttura dell\u2019anca</b> \u2014 collega il corpo agli
      arti posteriori."
  - key: REWARD_NIBBLES_BACK_ROW_FEMUR
    english: "<b>Femur / Thigh bone</b> \u2014 supports the body and helps with movement."
    deutsch: "<b>Femur / Oberschenkelknochen</b> \u2014 st\xFCtzt den K\xF6rper und
      hilft bei der Bewegung."
    francais: "<b>F\xE9mur / Os de la cuisse</b> \u2014 soutient le corps et aide
      au mouvement."
    italiano: "<b>Femore / Osso della coscia</b> \u2014 sostiene il corpo e aiuta
      nel movimento."
  - key: REWARD_NIBBLES_BACK_ROW_ASTRAGALOS
    english: "<b>Astragalos / Ankle bone</b> \u2014 helps transfer weight through
      the foot."
    deutsch: "<b>Astragalos / Sprunggelenksknochen</b> \u2014 hilft, Gewicht durch
      den Fu\xDF zu \xFCbertragen."
    francais: "<b>Astragale / Os de la cheville</b> \u2014 aide \xE0 transf\xE9rer
      le poids \xE0 travers le pied."
    italiano: "<b>Astragalo / Osso della caviglia</b> \u2014 aiuta a trasferire il
      peso attraverso il piede."
  - key: REWARD_YETI_BACK_ROW_CRANIUM
    english: "<b>Cranium</b> \u2014 protects the brain and supports the senses."
    deutsch: "<b>Cranium</b> \u2014 sch\xFCtzt das Gehirn und unterst\xFCtzt die
      Sinne."
    francais: "<b>Cr\xE2ne</b> \u2014 prot\xE8ge le cerveau et soutient les sens."
    italiano: "<b>Cranio</b> \u2014 protegge il cervello e sostiene i sensi."
  - key: REWARD_YETI_BACK_ROW_SCAPULA
    english: "<b>Scapula</b> \u2014 helps position the shoulder and guide arm movement."
    deutsch: "<b>Scapula</b> \u2014 hilft, die Schulter zu positionieren und die
      Armbewegung zu f\xFChren."
    francais: "<b>Scapula</b> \u2014 aide \xE0 positionner l\u2019\xE9paule et \xE0
      guider le mouvement du bras."
    italiano: "<b>Scapola</b> \u2014 aiuta a posizionare la spalla e a guidare il
      movimento del braccio."
  - key: REWARD_YETI_BACK_ROW_HUMERUS
    english: "<b>Humerus</b> \u2014 supports reaching, lifting, and front-limb movement."
    deutsch: "<b>Humerus</b> \u2014 unterst\xFCtzt Greifen, Heben und die Bewegung
      der vorderen Gliedma\xDFe."
    francais: "<b>Hum\xE9rus</b> \u2014 soutient les gestes pour atteindre, soulever
      et bouger le membre avant."
    italiano: "<b>Omero</b> \u2014 sostiene il raggiungere, il sollevare e il movimento
      dell\u2019arto anteriore."
  - key: REWARD_YETI_BACK_ROW_PELVIS
    english: "<b>Pelvis</b> \u2014 supports upright posture and connects the trunk
      to the legs."
    deutsch: "<b>Becken</b> \u2014 unterst\xFCtzt die aufrechte Haltung und verbindet
      den Rumpf mit den Beinen."
    francais: "<b>Bassin</b> \u2014 soutient la posture droite et relie le tronc
      aux jambes."
    italiano: "<b>Bacino</b> \u2014 sostiene la postura eretta e collega il tronco
      alle gambe."
  - key: REWARD_YETI_BACK_ROW_FEMUR
    english: "<b>Femur</b> \u2014 carries body weight during standing and walking."
    deutsch: "<b>Femur</b> \u2014 tr\xE4gt das K\xF6rpergewicht beim Stehen und Gehen."
    francais: "<b>F\xE9mur</b> \u2014 porte le poids du corps pendant la station
      debout et la marche."
    italiano: "<b>Femore</b> \u2014 sostiene il peso del corpo quando si sta in piedi
      e si cammina."
  - key: REWARD_YETI_BACK_ROW_ASTRAGALOS
    english: "<b>Astragalos</b> \u2014 helps balance the body and guide smooth ankle
      motion."
    deutsch: "<b>Astragalos</b> \u2014 hilft, den K\xF6rper auszubalancieren und
      eine geschmeidige Bewegung des Sprunggelenks zu f\xFChren."
    francais: "<b>Astragale</b> \u2014 aide \xE0 \xE9quilibrer le corps et \xE0 guider
      le mouvement fluide de la cheville."
    italiano: "<b>Astragalo</b> \u2014 aiuta a bilanciare il corpo e a guidare il
      movimento fluido della caviglia."
  - key: REWARD_ACHILLES_BACK_ROW_CRANIUM
    english: "<b>Cranium amulet</b> \u2014 can symbolize identity, thought, memory,
      or ancestry."
    deutsch: "<b>Cranium-Amulett</b> \u2014 kann Identit\xE4t, Denken, Erinnerung
      oder Abstammung symbolisieren."
    francais: "<b>Amulette du cr\xE2ne</b> \u2014 peut symboliser l\u2019identit\xE9,
      la pens\xE9e, la m\xE9moire ou l\u2019ascendance."
    italiano: "<b>Amuleto del cranio</b> \u2014 pu\xF2 simboleggiare identit\xE0,
      pensiero, memoria o origine."
  - key: REWARD_ACHILLES_BACK_ROW_SCAPULA
    english: "<b>Scapula amulet</b> \u2014 can suggest protection, strength, or movement."
    deutsch: "<b>Scapula-Amulett</b> \u2014 kann Schutz, St\xE4rke oder Bewegung
      andeuten."
    francais: "<b>Amulette de la scapula</b> \u2014 peut sugg\xE9rer la protection,
      la force ou le mouvement."
    italiano: "<b>Amuleto della scapola</b> \u2014 pu\xF2 suggerire protezione, forza
      o movimento."
  - key: REWARD_ACHILLES_BACK_ROW_HUMERUS
    english: "<b>Humerus amulet</b> \u2014 can represent action, work, or human ability."
    deutsch: "<b>Humerus-Amulett</b> \u2014 kann Handlung, Arbeit oder menschliche
      F\xE4higkeit darstellen."
    francais: "<b>Amulette de l\u2019hum\xE9rus</b> \u2014 peut repr\xE9senter l\u2019action,
      le travail ou la capacit\xE9 humaine."
    italiano: "<b>Amuleto dell\u2019omero</b> \u2014 pu\xF2 rappresentare azione,
      lavoro o capacit\xE0 umana."
  - key: REWARD_ACHILLES_BACK_ROW_PELVIS
    english: "<b>Pelvis amulet</b> \u2014 can symbolize support, life, posture, or
      origin."
    deutsch: "<b>Becken-Amulett</b> \u2014 kann Halt, Leben, Haltung oder Ursprung
      symbolisieren."
    francais: "<b>Amulette du bassin</b> \u2014 peut symboliser le soutien, la vie,
      la posture ou l\u2019origine."
    italiano: "<b>Amuleto del bacino</b> \u2014 pu\xF2 simboleggiare sostegno, vita,
      postura o origine."
  - key: REWARD_ACHILLES_BACK_ROW_FEMUR
    english: "<b>Femur amulet</b> \u2014 can represent strength, travel, or endurance."
    deutsch: "<b>Femur-Amulett</b> \u2014 kann St\xE4rke, Reise oder Ausdauer darstellen."
    francais: "<b>Amulette du f\xE9mur</b> \u2014 peut repr\xE9senter la force, le
      voyage ou l\u2019endurance."
    italiano: "<b>Amuleto del femore</b> \u2014 pu\xF2 rappresentare forza, viaggio
      o resistenza."
  - key: REWARD_ACHILLES_BACK_ROW_ASTRAGALOS
    english: "<b>Astragalos amulet</b> \u2014 can symbolize balance, movement, luck,
      or play."
    deutsch: "<b>Astragalos-Amulett</b> \u2014 kann Gleichgewicht, Bewegung, Gl\xFCck
      oder Spiel symbolisieren."
    francais: "<b>Amulette de l\u2019astragale</b> \u2014 peut symboliser l\u2019\xE9quilibre,
      le mouvement, la chance ou le jeu."
    italiano: "<b>Amuleto dell\u2019astragalo</b> \u2014 pu\xF2 simboleggiare equilibrio,
      movimento, fortuna o gioco."
  - key: INSTRUCTIONS_CHAPTER1_MECHANIC
    english: 'Drag each bone to its correct place in the skeleton.


      Tap on
      a bone to learn its name and what it does.'
    deutsch: 'Ziehe jeden Knochen an die richtige Stelle im Skelett.


      Tippe
      auf einen Knochen, um seinen Namen und seine Funktion zu lernen.'
    francais: "Fais glisser chaque os \xE0 la bonne place dans le squelette.\r\n\r\nAppuie
      sur un os pour apprendre son nom et sa fonction."
    italiano: 'Trascina ogni osso nella posizione corretta nello scheletro.


      Tocca
      un osso per scoprire il suo nome e la sua funzione.'
  - key: INSTRUCTIONS_CHAPTER2_MECHANIC
    english: "Drag each bone to the correct function. \n\nMatch bones with what they
      do in the body and complete all matches to finish the level."
    deutsch: "Ziehe jeden Knochen zur passenden Funktion. \n\nOrdne die Knochen ihrer
      Aufgabe im K\xF6rper zu und vervollst\xE4ndige alle Zuordnungen, um das Level
      abzuschlie\xDFen."
    francais: "Fais glisser chaque os vers la bonne fonction. \n\nAssocie les os
      \xE0 leur r\xF4le dans le corps et compl\xE8te toutes les associations pour
      terminer le niveau."
    italiano: 'Trascina ogni osso nella funzione corretta.


      Abbina le ossa
      al loro ruolo nel corpo e completa tutti gli abbinamenti per finire il livello.'
  - key: INSTRUCTIONS_CHAPTER3_MECHANIC
    english: 'Drag each amulet to the correct meaning.


      Look at the amulet
      clues, match them with what they represent, and complete all matches to finish
      the level.'
    deutsch: "Ziehe jedes Amulett zur richtigen Bedeutung.\n\nBetrachte die Hinweise
      der Amulette, ordne sie ihrer Bedeutung zu und vervollst\xE4ndige alle Zuordnungen,
      um das Level zu beenden."
    francais: "Fais glisser chaque amulette vers la bonne signification.\n\nObserve
      les indices des amulettes, associe-les \xE0 ce qu\u2019elles repr\xE9sentent
      et compl\xE8te toutes les associations pour terminer le niveau."
    italiano: "Trascina ogni amuleto verso il significato corretto.\n\nOsserva gli
      indizi degli amuleti, abbinali a ci\xF2 che rappresentano e completa tutti
      gli abbinamenti per finire il livello."
  - key: INSTRUCTIONS_STORY
    english: "You are a young apprentice in Darwin\u2019s lab. With the Chrono Engine,
      you travel through time to discover how bones connect anatomy, movement, history,
      and culture."
    deutsch: Du bist ein junger Lehrling in Darwins Labor. Mit der Chrono Engine
      reist du durch die Zeit, um zu entdecken, wie Knochen Anatomie, Bewegung, Geschichte
      und Kultur verbinden.
    francais: "Tu es un jeune apprenti dans le laboratoire de Darwin. Avec le Chrono
      Engine, tu voyages dans le temps pour d\xE9couvrir comment les os relient l\u2019anatomie,
      le mouvement, l\u2019histoire et la culture."
    italiano: Sei un giovane apprendista nel laboratorio di Darwin. Con il Chrono
      Engine viaggi nel tempo per scoprire come le ossa collegano anatomia, movimento,
      storia e cultura.
  - key: INSTRUCTIONS_REWARDS_TIMER_MISTAKES
    english: The timer shows how much time is left. The mistake counter shows how
      many wrong attempts you made.
    deutsch: "Der Timer zeigt, wie viel Zeit noch bleibt. Der Fehlerz\xE4hler zeigt,
      wie viele falsche Versuche du gemacht hast."
    francais: "Le chronom\xE8tre montre le temps restant. Le compteur d\u2019erreurs
      montre combien de mauvaises tentatives tu as faites."
    italiano: Il timer mostra quanto tempo resta. Il contatore degli errori mostra
      quanti tentativi sbagliati hai fatto.
  - key: INSTRUCTIONS_REWARDS_CARDS_RANKS
    english: After each mission, you unlock a Discovery Card. Cards help you review
      what you learned and can be Bronze, Silver, or Gold depending on your performance.
    deutsch: "Nach jeder Mission schaltest du eine Entdeckungskarte frei. Die Karten
      helfen dir, das Gelernte zu wiederholen, und k\xF6nnen je nach Leistung Bronze,
      Silber oder Gold sein."
    francais: "Apr\xE8s chaque mission, tu d\xE9bloques une carte de d\xE9couverte.
      Les cartes t\u2019aident \xE0 revoir ce que tu as appris et peuvent \xEAtre
      bronze, argent ou or selon ta performance."
    italiano: "Dopo ogni missione sblocchi una Carta Scoperta. Le carte ti aiutano
      a ripassare ci\xF2 che hai imparato e possono essere Bronzo, Argento o Oro
      in base alla tua prestazione."
  - key: INSTRUCTIONS_REWARDS_ASTRAGALOS
    english: Complete a mission with very few mistakes to receive the special Golden
      Astragalos badge.
    deutsch: "Schlie\xDFe eine Mission mit sehr wenigen Fehlern ab, um das besondere
      Goldene-Astragalus-Abzeichen zu erhalten."
    francais: "Termine une mission avec tr\xE8s peu d\u2019erreurs pour recevoir
      le badge sp\xE9cial Astragale dor\xE9."
    italiano: "Completa una missione con pochissimi errori per ricevere lo speciale
      distintivo Astragalo d\u2019oro."
