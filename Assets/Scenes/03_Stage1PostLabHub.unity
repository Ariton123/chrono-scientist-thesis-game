    openedCardTitle: Nibbles
    openedCardTitleKey: NIBBLES
    openedCardFrontDescription: "<b>Character:</b> Nibbles\n<b>Represents:</b> Brasilodon
      Quadrangularis\n<b>Era:</b> Late Triassic\n<b>Time:</b> about 225 million years
      ago\n<b>Status:</b> Extinct\n<b>Size:</b> roughly 20 cm long\n\n<b>Focus:</b>
      \nFossil reconstruction, skeleton assembly, and early mammal anatomy."
    openedCardFrontDescriptionKey: REWARD_NIBBLES_FRONT
    openedCardBackDescription: "In this mission, you learned the names of important
      bones and bone structures by rebuilding parts of Nibbles\u2019 skeleton."
    openedCardBackDescriptionKey: REWARD_NIBBLES_BACK
    blankAstragalosBadgeSprite: {fileID: 21300000, guid: f408db3e7dbfc8944820254d0731c923, type: 3}
